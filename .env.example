# Copy to .env (never commit .env). Without a key the app runs in demo mode
# with canned analyses — the demo still works end to end.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Optional: public URL sent as HTTP-Referer to OpenRouter
APP_PUBLIC_URL=http://localhost:8000
